{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Watchlist",
  "description": "Schema for driftwatch watchlist.json",
  "type": "object",
  "required": ["entries"],
  "properties": {
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["service", "added_at", "threshold"],
        "properties": {
          "service": {
            "type": "string",
            "minLength": 1,
            "description": "Name of the service to watch"
          },
          "added_at": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp when the entry was added"
          },
          "threshold": {
            "type": "integer",
            "minimum": 1,
            "description": "Minimum number of diffs required to trigger an alert"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
